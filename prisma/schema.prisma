generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  lastSeen  DateTime @updatedAt
  expiresAt DateTime

  tempEmails  TempEmail[]
  iptvLists   IptvList[]
  checkJobs   CheckJob[]
  favorites   Favorite[]
  watchHistory WatchHistory[]

  @@index([expiresAt])
}

model TempEmail {
  id        String   @id @default(uuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  address   String
  token     String
  accountId String
  provider  String   @default("mail.tm")
  createdAt DateTime @default(now())
  expiresAt DateTime

  messages EmailMessage[]

  @@index([sessionId])
  @@index([expiresAt])
}

model EmailMessage {
  id          String    @id
  email       TempEmail @relation(fields: [emailId], references: [id], onDelete: Cascade)
  emailId     String
  fromAddress String
  fromName    String
  subject     String
  intro       String?
  body        String?   @db.Text
  receivedAt  DateTime  @default(now())

  @@index([emailId])
}

model IptvList {
  id           String   @id @default(uuid())
  sessionId    String
  session      Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  url          String
  name         String   @default("")
  channelCount Int      @default(0)
  groups       String   @db.Text
  channels     String   @db.Text
  createdAt    DateTime @default(now())
  accessedAt   DateTime @updatedAt

  @@index([sessionId])
}

model CheckJob {
  id         String   @id @default(uuid())
  sessionId  String
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  inputMode  String   @default("url")
  serverHost String   @default("")
  totalLines Int      @default(0)
  results    String   @db.Text
  stats      String   @db.Text
  isComplete Boolean  @default(false)
  isRunning  Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([sessionId])
  @@index([isRunning])
}

model Favorite {
  id          String   @id @default(uuid())
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  channelName String
  channelUrl  String
  channelLogo String   @default("")
  channelGroup String  @default("")
  createdAt   DateTime @default(now())

  @@unique([sessionId, channelUrl])
  @@index([sessionId])
}

model WatchHistory {
  id          String   @id @default(uuid())
  sessionId   String
  session     Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  channelName String
  channelUrl  String
  channelLogo String   @default("")
  channelGroup String  @default("")
  watchedAt   DateTime @default(now())

  @@index([sessionId])
  @@index([watchedAt])
}
