generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  lastSeen  DateTime @updatedAt
  expiresAt DateTime

  tempEmails   TempEmail[]
  iptvLists    IptvList[]
  checkJobs    CheckJob[]
  favorites    Favorite[]
  watchHistory WatchHistory[]
  playerStates PlayerState[]

  @@index([expiresAt])
}

model TempEmail {
  id        String   @id @default(uuid())
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  address   String
  token     String
  accountId String
  provider  String   @default("mail.tm")
  createdAt DateTime @default(now())
  expiresAt DateTime

  messages EmailMessage[]

  @@index([sessionId])
  @@index([expiresAt])
}

model EmailMessage {
  id          String    @id
  email       TempEmail @relation(fields: [emailId], references: [id], onDelete: Cascade)
  emailId     String
  fromAddress String
  fromName    String
  subject     String
  intro       String?
  body        String?   @db.Text
  receivedAt  DateTime  @default(now())

  @@index([emailId])
}

model IptvList {
  id           String   @id @default(uuid())
  sessionId    String
  session      Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  url          String
  name         String   @default("")
  channelCount Int      @default(0)
  groups       String   @db.Text
  channels     String   @db.Text
  createdAt    DateTime @default(now())
  accessedAt   DateTime @updatedAt

  @@index([sessionId])
  @@index([sessionId, accessedAt])
}

model CheckJob {
  id          String       @id @default(uuid())
  sessionId   String
  session     Session      @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  inputMode   String       @default("url")
  serverHost  String       @default("")
  status      String       @default("running") // running, paused, completed, cancelled
  totalLines  Int          @default(0)
  processed   Int          @default(0)
  hits        Int          @default(0)
  bad         Int          @default(0)
  timeout     Int          @default(0)
  pendingLines String      @db.Text  // JSON array of lines still to process
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  completedAt DateTime?

  results CheckResult[]

  @@index([sessionId])
  @@index([status])
  @@index([sessionId, status])
}

model CheckResult {
  id        String   @id @default(uuid())
  jobId     String
  job       CheckJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  line      String
  status    String   // hit, bad, timeout
  host      String   @default("")
  username  String   @default("")
  password  String   @default("")
  metadata  String   @db.Text  // JSON with full result info
  createdAt DateTime @default(now())

  @@index([jobId])
  @@index([jobId, status])
  @@index([status])
}

model Favorite {
  id           String   @id @default(uuid())
  sessionId    String
  session      Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  channelName  String
  channelUrl   String
  channelLogo  String   @default("")
  channelGroup String   @default("")
  createdAt    DateTime @default(now())

  @@unique([sessionId, channelUrl])
  @@index([sessionId])
}

model WatchHistory {
  id           String   @id @default(uuid())
  sessionId    String
  session      Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  channelName  String
  channelUrl   String
  channelLogo  String   @default("")
  channelGroup String   @default("")
  watchedAt    DateTime @default(now())

  @@index([sessionId])
  @@index([watchedAt])
  @@index([sessionId, watchedAt])
}

model PlayerState {
  id             String   @id @default(uuid())
  sessionId      String
  session        Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  playlistUrl    String   @default("")
  currentChannel String   @db.Text  // JSON {name, url, logo, group}
  selectedGroup  String   @default("all")
  volume         Float    @default(0.8)
  isMuted        Boolean  @default(false)
  useProxy       Boolean  @default(false)
  updatedAt      DateTime @updatedAt

  @@unique([sessionId])
  @@index([sessionId])
}
